<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Dark Mode theme -->
    <style name="Theme.App" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_200</item>
        <item name="colorOnSecondary">@color:white</item>

        <!-- Background and surface -->
        <item name="android:windowBackground">@color/blue_gray_900</item>
        <item name="colorSurface">@color/blue_gray_900</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorBackground">@color/blue_gray_900</item>
        <item name="colorOnBackground">@color/white</item>

        <!-- Material components -->
        <item name="materialButtonStyle">@style/Widget.MaterialComponents.Button</item>
    </style>

    <!-- Splash Screen Theme (still light for branding) -->
    <style name="Theme.App.Splash" parent="Theme.App">
        <item name="android:windowBackground">@drawable/splash_background</item>
    </style>

</resources>
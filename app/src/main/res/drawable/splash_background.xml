<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base white background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#ffffff"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>

    <!-- Very soft depth shadow -->
    <item
        android:left="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#F3F4F6"/> <!-- ultra light gray -->
            <corners android:radius="14dp"/>
        </shape>
    </item>

    <!-- Faded stego hint layer (background only) -->
    <item
        android:left="6dp"
        android:top="6dp"
        android:right="6dp"
        android:bottom="6dp">
        <shape android:shape="rectangle">
            <solid android:color="#EEF2FF"/> <!-- very soft indigo tint -->
            <corners android:radius="12dp"/>
        </shape>
    </item>

</layer-list>
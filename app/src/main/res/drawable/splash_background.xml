<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base visible layer -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#020617"/> <!-- deep slate -->
            <corners android:radius="14dp"/>
        </shape>
    </item>

    <!-- Slight offset shadow (container depth) -->
    <item
        android:left="2dp"
        android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#020617"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>

    <!-- Hidden layer hint -->
    <item
        android:left="6dp"
        android:top="6dp">
        <shape android:shape="rectangle">
            <solid android:color="#0EA5E9"/> <!-- neon hint -->
            <corners android:radius="14dp"/>
        </shape>
    </item>

</layer-list>
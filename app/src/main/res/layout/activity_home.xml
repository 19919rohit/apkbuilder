<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080808">

    <!-- ══════════════════════════════════════════════════════
         SCROLLABLE BODY
         ══════════════════════════════════════════════════════ -->

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="96dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── HEADER ───────────────────────────────────── -->

            <LinearLayout
                android:id="@+id/headerSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="56dp"
                android:paddingBottom="6dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/greetingText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="#505050"
                        android:letterSpacing="0.02"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PageFlow"
                        android:textSize="34sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:letterSpacing="-0.015"
                        android:layout_marginTop="1dp"/>

                </LinearLayout>

                <!-- Avatar circle -->
                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="P"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#888888"
                    android:background="@drawable/bg_file_initial"/>

            </LinearLayout>

            <!-- ── CONTINUE READING ─────────────────────────── -->

            <LinearLayout
                android:id="@+id/continueSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="28dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONTINUE READING"
                    android:textSize="10sp"
                    android:letterSpacing="0.16"
                    android:textColor="#3A3A3A"
                    android:layout_marginBottom="12dp"/>

                <!-- Hero card -->
                <LinearLayout
                    android:id="@+id/continueCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:background="@drawable/bg_continue_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <!-- Thumbnail -->
                    <FrameLayout
                        android:layout_width="60dp"
                        android:layout_height="80dp"
                        android:background="@drawable/bg_recent_card">

                        <ImageView
                            android:id="@+id/continueThumbnail"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:visibility="gone"/>

                        <TextView
                            android:id="@+id/continueInitial"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="#2A2A2A"/>

                    </FrameLayout>

                    <!-- Info -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:id="@+id/continueTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="#F0F0F0"
                            android:textStyle="bold"
                            android:maxLines="2"
                            android:ellipsize="end"
                            android:lineSpacingMultiplier="1.25"/>

                        <TextView
                            android:id="@+id/continueSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="#484848"
                            android:layout_marginTop="5dp"/>

                        <!-- Progress track -->
                        <FrameLayout
                            android:id="@+id/progressTrack"
                            android:layout_width="match_parent"
                            android:layout_height="2dp"
                            android:layout_marginTop="10dp"
                            android:background="#1C1C1C">

                            <View
                                android:id="@+id/progressFill"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:background="#FFFFFF"/>

                        </FrameLayout>

                        <TextView
                            android:id="@+id/progressLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="10sp"
                            android:textColor="#333333"
                            android:layout_marginTop="5dp"/>

                    </LinearLayout>

                    <!-- Chevron -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="24sp"
                        android:textColor="#2A2A2A"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ── LIBRARY SECTION ──────────────────────────── -->

            <LinearLayout
                android:id="@+id/librarySection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="28dp"
                android:visibility="gone">

                <!-- Section header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="LIBRARY"
                        android:textSize="10sp"
                        android:letterSpacing="0.16"
                        android:textColor="#3A3A3A"/>

                    <TextView
                        android:id="@+id/clearAllBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Clear all"
                        android:textSize="11sp"
                        android:textColor="#2E2E2E"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="4dp"/>

                </LinearLayout>

                <!-- Horizontal book strip -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/bookStrip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:clipToPadding="false"
                    android:overScrollMode="never"/>

            </LinearLayout>

            <!-- ── ALL FILES ─────────────────────────────────── -->

            <LinearLayout
                android:id="@+id/allFilesSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="28dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ALL FILES"
                    android:textSize="10sp"
                    android:letterSpacing="0.16"
                    android:textColor="#3A3A3A"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:layout_marginBottom="8dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/allFilesRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"/>

            </LinearLayout>

            <!-- ── EMPTY STATE ──────────────────────────────── -->

            <LinearLayout
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingTop="80dp"
                android:paddingStart="48dp"
                android:paddingEnd="48dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:gravity="center"
                    android:text="📖"
                    android:textSize="34sp"
                    android:background="@drawable/bg_continue_card"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your library is empty"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#DDDDDD"
                    android:layout_marginTop="22dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Open a PDF to start reading.\nIt will appear here so you can pick up right where you left off."
                    android:textSize="13sp"
                    android:textColor="#3A3A3A"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.6"
                    android:layout_marginTop="10dp"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ══════════════════════════════════════════════════════
         OPEN PDF BUTTON — pinned bottom
         ══════════════════════════════════════════════════════ -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="28dp"
        android:paddingTop="20dp"
        android:background="@drawable/bg_bar_bottom">

        <TextView
            android:id="@+id/btnOpenPdf"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:gravity="center"
            android:text="Open PDF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:background="@drawable/bg_open_button"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
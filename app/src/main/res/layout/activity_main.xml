<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home"
    android:padding="24dp">

    <!-- HERO SECTION -->
    <LinearLayout
        android:id="@+id/heroSection"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/buttonsContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="60dp">

        <!-- App Name -->
        <TextView
            android:id="@+id/appTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STEGORA"
            android:textSize="34sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:textColor="@android:color/white"/>

        <!-- Subtitle -->
        <TextView
            android:id="@+id/appSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hide Files and Messages Secretly in Images"
            android:textSize="15sp"
            android:textColor="@android:color/white"
            android:alpha="0.85"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

    <!-- BUTTON SECTION -->
    <LinearLayout
        android:id="@+id/buttonsContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/heroSection"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp">

        <!-- Embed Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoEmbed"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Hide Secret"
            android:textSize="18sp"
            android:textColor="@color/text_on_primary"
            android:layout_marginBottom="16dp"
            app:icon="@drawable/ic_embed"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="@android:color/white"
            android:backgroundTint="@color/green"
            app:cornerRadius="12dp"
            android:foreground="?attr/selectableItemBackground"/>

        <!-- Extract Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoExtract"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Extract Secret"
            android:textSize="18sp"
            android:textColor="@color/text_on_primary"
            android:layout_marginBottom="16dp"
            app:icon="@drawable/ic_extract"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="@android:color/white"
            android:backgroundTint="@color/red"
            app:cornerRadius="12dp"
            android:foreground="?attr/selectableItemBackground"/>

        <!-- Files Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoFiles"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Files"
            android:textSize="18sp"
            android:textColor="@color/text_on_primary"
            app:icon="@drawable/ic_file"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="@android:color/white"
            android:backgroundTint="#0000FF"
            app:cornerRadius="12dp"
            android:foreground="?attr/selectableItemBackground"/>

    </LinearLayout>

    <!-- FOOTER -->
    <TextView
        android:id="@+id/footerText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v3.2.0"
        android:textSize="13sp"
        android:textColor="@android:color/white"
        android:alpha="0.7"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080808">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="96dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="56dp"
                android:paddingBottom="6dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_back"
                    android:tint="#888888"
                    android:background="@drawable/bg_file_initial"
                    android:contentDescription="Go back"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ABOUT THE APP"
                        android:textSize="11sp"
                        android:textColor="#8A8A8A"
                        android:letterSpacing="0.12"/>

                    <TextView
                        android:id="@+id/txtAppName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PageVibe"
                        android:textSize="34sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:letterSpacing="-0.015"
                        android:layout_marginTop="1dp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="APP INFORMATION"
                    android:textSize="10sp"
                    android:letterSpacing="0.16"
                    android:textColor="#707070"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/bg_continue_card">

                    <TextView
                        android:id="@+id/txtPackageName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="neunix.pagevibe"
                        android:textSize="14sp"
                        android:textColor="#F0F0F0"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtVersion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Version 1.0.0"
                        android:textSize="12sp"
                        android:textColor="#7A7A7A"
                        android:layout_marginTop="5dp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DESCRIPTION"
                    android:textSize="10sp"
                    android:letterSpacing="0.16"
                    android:textColor="#707070"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/bg_continue_card">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="PageVibe — User Guide

PageVibe is a PDF reader for Android that turns pages like a real book, lets you write on your documents, reads them aloud to you, and helps you pull important pages from multiple PDFs into one single file.

Opening a PDF

From the Home screen, tap "Open PDF" and choose any PDF file on your device. It's automatically saved to your Library so you can find it again later.

Reading

Swipe near the edge of the screen to turn a page — it curls just like a real page.

Pinch near the center of the screen to zoom in, then pan around while zoomed.

Double-tap to quickly zoom in or back out.

Use the slider at the bottom to jump to any page instantly.

Searching

Tap the magnifying glass icon and type any word or phrase. Every place it appears in the document gets highlighted right on the page. Use the arrows to jump between matches.

Bookmarks

Tap the star icon to bookmark the page you're on. Tap the bookmark list icon to see all your saved pages as visual thumbnail cards.

Listening (Read Aloud)

Tap the speaker icon and PageVibe will read the current page aloud, with the exact word being spoken highlighted as it goes. Tap Pause/Play to stop and resume without losing your place.

Writing and Highlighting

Tap the pen icon to open the drawing tools. Choose a pen or highlighter, pick a color, and write directly on the page. Your notes are saved automatically.

Page Basket — Combine Pages from Different PDFs

This is PageVibe's most useful feature for studying.

While reading any PDF, tap the basket icon on a page you want to keep.

Open a different PDF and add more pages. They all go into the same basket.

Go to the Basket tab to see everything you've collected. Drag pages to reorder them.

Tap "Create PDF from Basket," give it a name, and a new merged PDF is saved directly to your phone's Documents folder, ready to share or print.

Your Library

The Library tab shows every PDF you've ever opened as a grid of covers.

Long-press any book to:

Change Cover — Pick any photo as that book's cover image.

Rename — Give it a name that makes sense to you.

Delete from Library — Remove it from the library. Your original file on your device is never touched.

Use the search bar at the top to find a book instantly, and tap "Sort By" in the top-right corner to switch between Recent and A–Z ordering.

Your Reading Stats

Tap the Insights card on the Home screen to see:

Your current daily reading streak.

How long you've read today and over the last 7 days.

Your most-read book overall.

A short motivational note that changes once per day.

Privacy

PageVibe works completely offline. Your PDFs, notes, and reading activity never leave your device. There's no account, no cloud sync, and nothing is ever uploaded anywhere."
                        android:textSize="13sp"
                        android:textColor="#A0A0A0"
                        android:lineSpacingMultiplier="1.4"/>
                    
                </LinearLayout>
            </LinearLayout>
            <TextView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="24dp"
    android:layout_marginBottom="16dp"
    android:gravity="center"
    android:text="Built by Neunix Studios"
    android:textSize="12sp"
    android:textColor="#5F5F5F"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="28dp"
        android:paddingTop="20dp"
        android:background="@drawable/bg_bar_bottom">

        <TextView
            android:id="@+id/btnLicenses"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:gravity="center"
            android:text="Open Source Licenses"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

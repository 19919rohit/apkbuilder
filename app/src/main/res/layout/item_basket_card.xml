<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_margin="8dp"
    android:padding="10dp"
    android:background="@drawable/bg_continue_card">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="@drawable/bg_recent_card">

        <ImageView
            android:id="@+id/basketCardThumbnail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"/>

        <TextView
            android:id="@+id/basketCardInitial"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#2A2A2A"/>

        <TextView
            android:id="@+id/basketCardPageBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_margin="8dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:background="@drawable/bg_button_dark"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>

        <ImageButton
            android:id="@+id/basketCardRemove"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="top|end"
            android:layout_margin="6dp"
            android:src="@drawable/ic_close"
            android:background="@drawable/bg_button_dark"
            android:padding="5dp"
            android:tint="#CCCCCC"
            android:contentDescription="Remove from basket"/>

    </FrameLayout>

    <TextView
        android:id="@+id/basketCardTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="#BBBBBB"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginTop="7dp"
        android:layout_marginStart="2dp"/>

</LinearLayout>
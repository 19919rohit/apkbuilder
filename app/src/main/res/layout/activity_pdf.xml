<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <neunix.pagevibe.GalleryZoomView
        android:id="@+id/zoomContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFFFF">

        <neunix.pagevibe.CurlView
            android:id="@+id/curlView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <neunix.pagevibe.DrawingView
            android:id="@+id/drawingView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="false"
            android:focusable="false"/>

        <neunix.pagevibe.HighlightOverlayView
            android:id="@+id/highlightOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="false"
            android:focusable="false"/>

    </neunix.pagevibe.GalleryZoomView>

    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC0A0A0A"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:indeterminateTint="#FFFFFF"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="72dp"
            android:text="Opening PDF…"
            android:textSize="13sp"
            android:textColor="#888888"/>

    </FrameLayout>

    <LinearLayout
        android:id="@+id/errorView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="40dp"
        android:background="#CC0A0A0A"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="!"
            android:textSize="48sp"
            android:textColor="#FF5555"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Could not open PDF"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginTop="12dp"/>

        <TextView
            android:id="@+id/errorMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginTop="8dp"
            android:lineSpacingMultiplier="1.4"/>

        <TextView
            android:id="@+id/btnRetryOpen"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="Open another PDF"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_button_dark"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/searchPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F0111111"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="52dp"
        android:paddingBottom="10dp"
        android:visibility="gone"
        android:translationY="-300dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_button_dark">

            <EditText
                android:id="@+id/searchInput"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Search text in PDF…"
                android:textColorHint="#444444"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:paddingStart="14dp"
                android:paddingEnd="6dp"
                android:background="@null"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:singleLine="true"/>

            <ImageButton
                android:id="@+id/btnSearchPrev"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_back"
                android:rotation="90"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#888888"
                android:contentDescription="Previous result"/>

            <ImageButton
                android:id="@+id/btnSearchNext"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_back"
                android:rotation="270"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#888888"
                android:contentDescription="Next result"/>

            <ImageButton
                android:id="@+id/btnSearchClose"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_close"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#888888"
                android:contentDescription="Close search"/>

        </LinearLayout>

        <TextView
            android:id="@+id/searchResultText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#555555"
            android:paddingStart="4dp"
            android:paddingTop="6dp"
            android:maxLines="2"
            android:ellipsize="end"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:background="@drawable/bg_bar_top">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Back"/>

        <TextView
            android:id="@+id/titleText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="14sp"
            android:textColor="#EEEEEE"
            android:maxLines="1"
            android:ellipsize="middle"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"/>

        <ImageButton
            android:id="@+id/btnSearch"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_search"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Search"/>

        <ImageButton
            android:id="@+id/btnBookmark"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_star"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Bookmark this page"/>

        <ImageButton
            android:id="@+id/btnBookmarkList"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_bookmarks"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="All bookmarks"/>

        <ImageButton
            android:id="@+id/btnAddToBasket"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_basket_outline"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Add page to basket"/>

        <ImageButton
            android:id="@+id/btnToc"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_toc"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Table of contents"/>

        <ImageButton
            android:id="@+id/btnOpenNew"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_open_new"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Open PDF"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/drawToolbar"
        android:layout_width="56dp"
        android:layout_height="wrap_content"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="8dp"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="8dp"
        android:background="@drawable/bg_continue_card"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/btnPen"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_pen"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Pen"/>

        <ImageButton
            android:id="@+id/btnHighlighter"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_highlighter"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#666666"
            android:contentDescription="Highlighter"/>

        <View
            android:layout_width="36dp"
            android:layout_height="1dp"
            android:background="#2A2A2A"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"/>

        <ImageButton
            android:id="@+id/penThin"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_pen_thin"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#AAAAAA"
            android:contentDescription="Thin pen"/>

        <ImageButton
            android:id="@+id/penThick"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_pen_thick"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Thick pen"/>

        <View
            android:layout_width="36dp"
            android:layout_height="1dp"
            android:background="#2A2A2A"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"/>

        <View
            android:id="@+id/colorRed"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:background="#FF4444"
            android:layout_margin="4dp"/>

        <View
            android:id="@+id/colorBlue"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:background="#4488FF"
            android:layout_margin="4dp"/>

        <View
            android:id="@+id/colorYellow"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:background="#FFEE00"
            android:layout_margin="4dp"/>

        <View
            android:id="@+id/colorWhite"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:background="#FFFFFF"
            android:layout_margin="4dp"/>

        <View
            android:id="@+id/colorGreen"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:background="#44DD88"
            android:layout_margin="4dp"/>

        <View
            android:layout_width="36dp"
            android:layout_height="1dp"
            android:background="#2A2A2A"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"/>

        <ImageButton
            android:id="@+id/btnDrawUndo"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_undo"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#AAAAAA"
            android:contentDescription="Undo last stroke"/>

        <ImageButton
            android:id="@+id/btnDrawClear"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FF5555"
            android:contentDescription="Clear all drawings"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/readAloudBar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="112dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:background="@drawable/bg_continue_card"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/btnTtsPlayPause"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_play"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Play or pause"/>

        <TextView
            android:id="@+id/ttsStatusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="#888888"
            android:paddingStart="10dp"
            android:paddingEnd="4dp"
            android:maxLines="1"
            android:ellipsize="end"/>

        <ImageButton
            android:id="@+id/btnTtsStop"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_stop"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#444444"
            android:contentDescription="Stop reading"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/controlBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="24dp"
        android:background="@drawable/bg_bar_bottom">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="2dp">

            <TextView
                android:id="@+id/pageText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 / 0"
                android:textSize="13sp"
                android:textColor="#AAAAAA"
                android:textStyle="bold"
                android:letterSpacing="0.04"/>

            <ImageButton
                android:id="@+id/btnDraw"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_pen"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#FFFFFF"
                android:contentDescription="Draw on page"/>

            <ImageButton
                android:id="@+id/btnReadAloud"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_speak"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#FFFFFF"
                android:contentDescription="Read aloud"/>

        </LinearLayout>

        <com.google.android.material.slider.Slider
            android:id="@+id/pageSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="0"
            android:valueTo="1"
            app:thumbColor="#FFFFFF"
            app:thumbRadius="8dp"
            app:trackColorActive="#FFFFFF"
            app:trackColorInactive="#2A2A2A"
            app:trackHeight="2dp"
            app:haloColor="#33FFFFFF"
            app:haloRadius="16dp"
            app:labelBehavior="gone"/>

    </LinearLayout>

    <FrameLayout
        android:id="@+id/tocSheetBackdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone"/>

    <LinearLayout
        android:id="@+id/tocSheet"
        android:layout_width="match_parent"
        android:layout_height="520dp"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bg_continue_card"
        android:visibility="gone"
        android:translationY="2000dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Table of Contents"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#F0F0F0"/>

            <ImageButton
                android:id="@+id/btnTocClose"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_close"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#555555"
                android:contentDescription="Close contents"/>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1E1E1E"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/tocRecycler"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:overScrollMode="never"
            android:paddingBottom="20dp"
            android:clipToPadding="false"/>

    </LinearLayout>

    <FrameLayout
        android:id="@+id/bookmarkSheetBackdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone"/>

    <LinearLayout
        android:id="@+id/bookmarkSheet"
        android:layout_width="match_parent"
        android:layout_height="460dp"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bg_continue_card"
        android:visibility="gone"
        android:translationY="2000dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Bookmarks"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#F0F0F0"/>

            <ImageButton
                android:id="@+id/btnBookmarkSheetClose"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_close"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#555555"
                android:contentDescription="Close bookmarks"/>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1E1E1E"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/bookmarkRecycler"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:overScrollMode="never"
            android:paddingBottom="20dp"
            android:clipToPadding="false"
            android:visibility="gone"/>

        <LinearLayout
            android:id="@+id/bookmarkEmptyState"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="★"
                android:textSize="40sp"
                android:textColor="#333333"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No bookmarks yet"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginTop="12dp"/>

        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/bookmarkToast"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="80dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:background="@drawable/bg_button_dark"
        android:textSize="13sp"
        android:textColor="#FFFFFF"
        android:visibility="gone"/>

</FrameLayout>
<?xml version="1.0" encoding="utf-8"?>

<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <!-- ══════════════════════════════════════════════════════
         GL SURFACE — full screen, behind everything
         ══════════════════════════════════════════════════════ -->

    <neunix.pageflow.PageFlipGLView
        android:id="@+id/pageFlipGL"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- ══════════════════════════════════════════════════════
         LOADING OVERLAY
         Shown while PDF is opening or a page is rendering.
         Semi-transparent so the previous page shows through.
         ══════════════════════════════════════════════════════ -->

    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC0A0A0A"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/loadingSpinner"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:indeterminateTint="#FFFFFF"/>

        <TextView
            android:id="@+id/loadingLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="72dp"
            android:text="Opening PDF…"
            android:textSize="13sp"
            android:textColor="#888888"/>

    </FrameLayout>

    <!-- ══════════════════════════════════════════════════════
         ERROR OVERLAY
         Shown when the PDF fails to open or a page fails to
         render. Never silent — always tells the user what
         went wrong and what they can do.
         ══════════════════════════════════════════════════════ -->

    <LinearLayout
        android:id="@+id/errorView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="40dp"
        android:background="#CC0A0A0A"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="!"
            android:textSize="48sp"
            android:textColor="#FF5555"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Something went wrong"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginTop="12dp"/>

        <TextView
            android:id="@+id/errorMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginTop="8dp"
            android:lineSpacingMultiplier="1.4"/>

        <TextView
            android:id="@+id/btnRetryOpen"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="Open another PDF"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_button_dark"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════
         TOP BAR
         Auto-hides after 3 seconds. Contains back button,
         file name, and open-new button.
         ══════════════════════════════════════════════════════ -->

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="@drawable/bg_bar_top">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:tint="#FFFFFF"/>

        <TextView
            android:id="@+id/titleText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="15sp"
            android:textColor="#EEEEEE"
            android:maxLines="1"
            android:ellipsize="middle"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"/>

        <ImageButton
            android:id="@+id/btnOpenNew"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_open_new"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Open PDF"
            android:tint="#FFFFFF"/>

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════
         CONTROL BAR  (bottom)
         Auto-hides with the top bar. Contains page counter
         and scrub slider. Both snap-hide together so the
         reading surface is completely clean.
         ══════════════════════════════════════════════════════ -->

    <LinearLayout
        android:id="@+id/controlBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp"
        android:background="@drawable/bg_bar_bottom">

        <!-- Page counter + chapter label row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/pageText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 / 0"
                android:textSize="13sp"
                android:textColor="#AAAAAA"
                android:textStyle="bold"
                android:letterSpacing="0.04"/>

        </LinearLayout>

        <!-- Scrub slider -->
        <com.google.android.material.slider.Slider
            android:id="@+id/pageSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="0"
            android:valueTo="1"
            app:thumbColor="#FFFFFF"
            app:thumbRadius="8dp"
            app:trackColorActive="#FFFFFF"
            app:trackColorInactive="#333333"
            app:trackHeight="2dp"
            app:haloColor="#33FFFFFF"
            app:haloRadius="16dp"
            app:labelBehavior="gone"/>

    </LinearLayout>

</FrameLayout>
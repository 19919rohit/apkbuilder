<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Back Button -->
    <ImageView
        android:id="@+id/backButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:padding="6dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_back"
        android:contentDescription="Back"/>

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Files"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="24dp"/>

    <!-- Embedded Files Button -->
    <Button
        android:id="@+id/btnEmbeddedFiles"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Embedded Images"
        android:drawableStart="@drawable/ic_embed"
        android:drawablePadding="10dp"
        android:layout_marginBottom="16dp"/>

    <!-- Extracted Files Button -->
    <Button
        android:id="@+id/btnExtractedFiles"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Extracted Files"
        android:drawableStart="@drawable/ic_extract"
        android:drawablePadding="10dp"/>

</LinearLayout>
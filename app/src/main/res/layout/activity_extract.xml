<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#0F172A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:animateLayoutChanges="true">

        <!-- Carrier Image Preview -->
        <ImageView
            android:id="@+id/carrierPreview"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="#020617"
            android:scaleType="centerCrop"
            android:layout_marginBottom="12dp"/>

        <!-- Pick Carrier -->
        <Button
            android:id="@+id/pickCarrierBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select Stego Image"
            android:backgroundTint="#2563EB"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="12dp"/>

        <!-- Password -->
        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Password (if any)"
            android:inputType="textPassword"
            android:textColor="#FFFFFF"
            android:textColorHint="#64748B"
            android:layout_marginBottom="12dp"/>

        <!-- Output filename -->
        <EditText
            android:id="@+id/etOutputFileName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Output file name (e.g. extracted.bin)"
            android:textColor="#FFFFFF"
            android:textColorHint="#64748B"
            android:layout_marginBottom="20dp"/>

        <!-- Progress -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="16dp"/>

        <!-- Extract Button -->
        <Button
            android:id="@+id/btnExtract"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Extract Payload"
            android:backgroundTint="#DC2626"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="12dp"/>

    </LinearLayout>
</ScrollView>
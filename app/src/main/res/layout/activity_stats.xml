<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080808">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="48dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="56dp"
                android:paddingBottom="6dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_back"
                    android:tint="#888888"
                    android:background="@drawable/bg_file_initial"
                    android:contentDescription="Go back"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="YOUR PROGRESS"
                        android:textSize="11sp"
                        android:textColor="#8A8A8A"
                        android:letterSpacing="0.12"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reading Stats"
                        android:textSize="34sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:letterSpacing="-0.015"
                        android:layout_marginTop="1dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- TOP NUMBERS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="24dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="18dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_continue_card">

                    <TextView
                        android:id="@+id/statTotalTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0m"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total reading time"
                        android:textSize="11sp"
                        android:textColor="#7A7A7A"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="18dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_continue_card">

                    <TextView
                        android:id="@+id/statTotalPages"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pages turned"
                        android:textSize="11sp"
                        android:textColor="#7A7A7A"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- STREAK -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="18dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_continue_card">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥"
                    android:textSize="26sp"
                    android:layout_marginEnd="14dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/statStreak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 day streak"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Keep reading daily to build your streak"
                        android:textSize="11sp"
                        android:textColor="#7A7A7A"
                        android:layout_marginTop="3dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- RECENT ACTIVITY — no fixed day count in the label; the
                 chart itself only ever shows as many days as have real
                 history, up to 7, starting with Today. -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RECENT ACTIVITY"
                android:textSize="10sp"
                android:letterSpacing="0.16"
                android:textColor="#707070"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:id="@+id/weekChart"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:padding="16dp"
                android:background="@drawable/bg_continue_card"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"/>

            <!-- MOST READ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MOST READ"
                android:textSize="10sp"
                android:letterSpacing="0.16"
                android:textColor="#707070"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:id="@+id/mostReadCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:background="@drawable/bg_continue_card"
                android:visibility="gone">

                <TextView
                    android:id="@+id/mostReadTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#F0F0F0"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/mostReadTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#7A7A7A"
                    android:layout_marginTop="5dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/emptyStatsMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No reading recorded yet — open a PDF and start reading to see your stats here."
                android:textSize="13sp"
                android:textColor="#6A6A6A"
                android:gravity="center"
                android:lineSpacingMultiplier="1.5"
                android:paddingStart="40dp"
                android:paddingEnd="40dp"
                android:paddingTop="40dp"
                android:visibility="gone"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
<?xml version="1.0" encoding="utf-8"?>
<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.neunix.appstore">

    <!-- ================= REQUIRED PERMISSIONS ================= -->

    <!-- Internet: needed for GitHub releases, images, APK download -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Network state: optional but recommended -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Required to install APKs from inside the app -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- Optional: for showing installed apps info (PackageManager) -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />

    <!-- ========================================================= -->

    <!-- Required for Android 11+ package visibility -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:mimeType="application/vnd.android.package-archive" />
        </intent>
    </queries>

    <application
        android:label="Neunix Store"
        android:icon="@drawable/ic_launcher"
        android:allowBackup="true"
        android:supportsRtl="true"
        android:usesCleartextTraffic="false"
        android:theme="@style/Theme.Material3.DayNight.NoActionBar">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

    </application>

</manifest>
<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ===== Permissions (SAFE + Play Store compliant) ===== -->

    <!-- For file picking via SAF (Android 12 and below) -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Legacy write support (below Android 10) -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- Permission to save images to MediaStore (Android 10+) -->
    <uses-permission android:name="android.permission.ACCESS_MEDIA_LOCATION" />

    <application
        android:allowBackup="true"
        android:supportsRtl="true"
        android:label="StegoBox"
        android:icon="@drawable/ic_launcher"
        android:theme="@style/Theme.App">

        <!-- ===================== -->
        <!-- Splash Screen -->
        <!-- ===================== -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.App.Splash">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!-- ===================== -->
        <!-- Home Screen -->
        <!-- ===================== -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- ===================== -->
        <!-- Embed Screen -->
        <!-- ===================== -->
        <activity
            android:name=".EmbedActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- ===================== -->
        <!-- Extract Screen -->
        <!-- ===================== -->
        <activity
            android:name=".ExtractActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

    </application>

</manifest>